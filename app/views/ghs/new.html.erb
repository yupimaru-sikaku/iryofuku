  <p class="alert_danger" style=" color: red;">
    <%= @gh.errors.full_messages_for(:human_name).first %>
  <div class="module-spacer--small"></div>
  <% end %>

  <div class="gh-new-field">
    <div class="gh-new-field-1">
      <%= f.label :human_name, 'ご担当者名  ※ご担当者に変更がある場合は変更してください。'%>
      <span>（必須）</span>
    </div>
    <div class="gh-new-field-2">
      <%= f.text_field :human_name, placeholder: '例）山田 太郎', value: current_company.name %>
