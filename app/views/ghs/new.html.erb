    <div class="gh-new-field-check-1">
      <% ["男性", "女性"].each do |gender| %>
      <div class="gh-new-field-check-1">
        <%= f.check_box :gender, {id: "gender#{gender}", multiple: true, include_hidden: false, class: 'gender', checked: is_checked?(:gh, :gender, gender)}, gender %>
        <%= f.label :gender, gender, for: "gender#{gender}" %>
      </div>
      <% end %>
    </div>
  </div>

