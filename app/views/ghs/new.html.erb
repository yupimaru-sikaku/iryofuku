<%= render partial: 'shared/company_menu' %>

<%#GH新規作成%>
<div class="gh-new-content">

  <div class="module-spacer--large"></div>

  <%#GH新規作成タイトル%>
  <div class="gh-new-title">
    <p>事業所登録画面<span>- 共同生活援助 -</span></p>
  </div>
  <%#//GH新規作成タイトル%>

  <div class="module-spacer--medium"></div>

  <%#GH新規作成フォーム%>
  <%= form_with model: @gh, class: 'gh-new-fields', name: "form", local: true do |f| %>

  <div class="module-spacer--small"></div>

  <% if @gh.errors.include?(:main_company_name) %>
  <p class="alert_danger" style=" color: red;">
    <%= @gh.errors.full_messages_for(:main_company_name).first %>
  <div class="module-spacer--small"></div>
  <% end %>

  <div class="gh-new-field">
    <div class="gh-new-field-1">
      <%= f.label :main_company_name, '法人名'%>
      <span>（必須）</span>
    </div>
    <div class="gh-new-field-2">
      <%= f.text_field :main_company_name, placeholder: '例）株式会社〇〇', value: current_company.company_name %>
      <span></span>
    </div>
  </div>

  <div class="module-spacer--medium"></div>

  <% if @gh.errors.include?(:sub_company_name) %>
  <p class="alert_danger" style=" color: red;">
    <%= @gh.errors.full_messages_for(:sub_company_name).first %>
  <div class="module-spacer--small"></div>
  <% end %>

  <div class="gh-new-field">
    <div class="gh-new-field-1">
      <%= f.label :sub_company_name, '事業所名'%>
      <span>（必須）</span>
    </div>
    <div class="gh-new-field-2">
      <%= f.text_field :sub_company_name, placeholder: '例）グループホーム〇〇' %>
      <span></span>
    </div>
  </div>

  <div class="module-spacer--medium"></div>

  <% if @gh.errors.include?(:postal_code) %>
  <p class="alert_danger" style=" color: red;">
    <%= @gh.errors.full_messages_for(:postal_code).first %>
  <div class="module-spacer--small"></div>
  <% end %>

  <div class="gh-new-field middle_input">
    <div class="gh-new-field-1">
      <%= f.label :postal_code, '事業所の郵便番号（半角、ハイフン無し）'%>
      <span>（必須）</span>
    </div>
    <div class="gh-new-field-2">
      <%= f.text_field :postal_code, placeholder: '例）1234567（ハイフン無し）', id: 'postal_code', maxlength: '7' %>
      <span><button id="address_btn">住所検索</button></span>
    </div>
  </div>

  <div class="module-spacer--medium"></div>

  <% if @gh.errors.include?(:address) %>
  <p class="alert_danger" style=" color: red;">
    <%= @gh.errors.full_messages_for(:address).first %>
  <div class="module-spacer--small"></div>
  <% end %>

  <div class="gh-new-field">
    <div class="gh-new-field-1">
      <%= f.label :address, '事業所の住所'%>
      <span>（必須）</span>
    </div>
    <div class="gh-new-field-2">
      <%= f.text_field :address, id: 'address_city' %>
      <span></span>
    </div>
  </div>

  <div class="module-spacer--medium"></div>

  <% if @gh.errors.include?(:phone_number) %>
