      <%= f.label :from_station, '最寄り駅から徒歩何分'%>
      <span>（必須）</span>
    </div>
    <div class="gh-new-field-radio middle_height">
      <% ["〜5分", "〜10分", "〜15分", "〜20分", "〜25分", "〜30分", "〜40分", "40分以上"].each do |from_station| %>
      <div class="gh-new-field-radio-1">
        <%= f.radio_button :from_station, from_station, id: "from_station#{from_station}" %>
        <%= f.label :from_station, from_station, for: "from_station#{from_station}" %>
      </div>
      <% end %>
    </div>
  </div>

  <div class="module-spacer--medium"></div>

