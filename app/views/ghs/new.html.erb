      <%= f.text_field :construction_year, placeholder: '例）1992', maxlength: '4' %>
      <span>年</span>
      <%= f.text_field :construction_month, placeholder: '例）3', maxlength: '2' %>
      <span>月</span>
      <%= f.hidden_field :building_age %>
    </div>
  </div>

  <div class="module-spacer--medium"></div>

  <% if @gh.errors.include?(:designated_year) %>
  <p class="alert_danger" style=" color: red;">
    <%= @gh.errors.full_messages_for(:designated_year).first %>
  <div class="module-spacer--small"></div>
  <% end %>
  <% if @gh.errors.include?(:designated_month) %>
  <p class="alert_danger" style=" color: red;">
    <%= @gh.errors.full_messages_for(:designated_month).first %>
  <div class="module-spacer--small"></div>
