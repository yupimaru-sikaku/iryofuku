<%#大枠%>
<section class="sagaseru-container">

  <%#仮置%>
  <% if company_signed_in? %>
  <p><%= current_company.company_name %>でログインしています</p>
  <%= link_to '（仮置）ログアウト', destroy_user_session_path, method: :delete %>
  <% end %>
  <%= link_to '（仮置）ユーザーの新規登録画面だよ', new_company_registration_path %>
  <% unless company_signed_in? %>
  <%= link_to '（仮置）ログインはこちら', new_company_session_path %>
  <% end %>
  <%= link_to '（仮置き）希望利用者の新規作成', new_sagaseru_path %>
  <%= link_to '（仮置き）希望利用者の一覧', sagaserus_path %>
  <%= link_to '（仮置き）ghの申請画面', new_gh_path %>

  <%#//仮置%>


  <%#サガセルの説明%>
  <div class="sagaseru-description">
    <div class="sagaseru-description-text">
      <span>利用者紹介サービス</span>
      <p>障害福祉サービスを利用したい方をご紹介致します。<br><br>まずは下記のお問い合わせフォームから<br>必要事項をご記入の上、送信ボタンを押して下さい。<br><br>追って、ご連絡致します。</p>
    </div>
    <div class="sagaseru-description-img">
      <%= image_tag "5 - RECRUITING.svg" %>
    </div>
  </div>
  <%#//サガセルの説明%>

  <div class="module-spacer--large"></div>
  <div class="module-spacer--large"></div>

  <%# コンタクトフォーム %>
  <%= render partial: 'shared/contact_form', locals: {path: contact_message_sagaserus_path} %>
  <%#// コンタクトフォーム %>

  <div class="module-spacer--large"></div>

</section>
<%#//大枠%>

<%= javascript_pack_tag 'sagaserus/contact' %>