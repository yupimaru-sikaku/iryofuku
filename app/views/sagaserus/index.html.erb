<%= render partial: 'shared/company_header' %>
<%= render partial: 'shared/hamburger' %>

<%#大枠%>
<section class="sagaseru-index-content">

  <%#タイトル%>
  <p class="sageseru-index-title">ご入居希望者様を探す</p>
  <%#//タイトル%>

  <div class="module-spacer--medium"></div>

  <%#検索項目%>
  <div class="sagaseru-search-forms">
    <%= form_with(scope: :search, url: sagaserus_path, method: :get, local: true) do |f| %>

    <div class="sagaseru-search-form">
      <%= f.label :prefecture_id, '都道府県' %>
      <%= f.collection_select :prefecture_id, Prefecture.all, :id, :name, selected: @search_params[:prefecture_id], include_blank: '指定なし'  %>
    </div>

    <div class="sagaseru-search-form">
      <%= f.label :osaka_city_id, '市町村' %>
      <%= f.collection_select :osaka_city_id, OsakaCity.all, :id, :name, selected: @search_params[:osaka_city_id], include_blank: '指定なし' %>
    </div>

    <div class="sagaseru-search-form">
      <%= f.label :service_type_id, 'サービスの種別' %>
      <%= f.collection_select :service_type_id, ServiceType.all, :id, :name, selected: @search_params[:service_type_id], include_blank: '指定なし' %>
    </div>

    <div class="sagaseru-search-form">
      <%= f.label :disability_type_id, '障害の種別' %>
      <%= f.collection_select :disability_type_id, DisabilityType.all, :id, :name, selected: @search_params[:disability_type_id], include_blank: '指定なし' %>
    </div>

    <div class="sagaseru-search-form">
      <%= f.label :sex_id, '性別' %>
      <%= f.collection_select :sex_id, Sex.all, :id, :name, selected: @search_params[:sex_id], include_blank: '指定なし' %>
    </div>

    <div class="sagaseru-search-form">
      <%= f.label :age, 'ご年齢' %>
      <%= f.number_field :age_from, value: @search_params[:age_from] %>歳 ~ <%= f.number_field :age_to, value: @search_params[:age_to] %>歳
    </div>

    <div class="sagaseru-search-btn">
      <%= f.submit '検索' %>
    </div>
    <% end %>

    <%#検索初期化%>
    <div class="sagaseru-index-reset">
      <%= link_to 'リセット', sagaserus_path %>
    </div>
    <%#//検索初期化%>

  </div>
  <%#//検索項目%>

  <div class="module-spacer--medium"></div>

  <%#登録者一覧%>
  <div class="sagaseru-indexes">
    <table>
      <thead>
        <tr>
          <th>都道府県</th>
          <th>市町村</th>
          <th>ご希望のサービス種別</th>
          <th>障がいの種別</th>
          <th>性別</th>
          <th>ご年齢</th>
          <th>更新日</th>
          <th>申請ボタン</th>
        </tr>
      </thead>
      <tbody>
        <% @sagaserus_search.each do |sagaseru| %>
        <tr>
          <td><%= sagaseru.prefecture.name %></td>
          <td><%= sagaseru.osaka_city.name %></td>
          <td><%= sagaseru.service_type.name %></td>
          <td><%= sagaseru.disability_type.name %></td>
          <td><%= sagaseru.sex.name %></td>
          <td><%= "#{sagaseru.age}歳" %></td>
          <td><%= sagaseru.updated_at.strftime("%Y.%m.%d ") %></td>
          <td>
            <div id="favorites_button-<%= sagaseru.id %>">
              <%= render partial: "favorites/favorites", locals: { sagaseru: sagaseru } %>
            </div>
          </td>
        </tr>
        <% end %>
      </tbody>
    </table>
  </div>
  <%#//登録者一覧%>

</section>
<%#//大枠%>