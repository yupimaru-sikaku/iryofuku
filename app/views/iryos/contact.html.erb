<%= render partial: 'shared/header' %>

<div class="module-spacer--large"></div>

<%#大枠%>
<section class="iryo-container">

  <%#サガセルの説明%>
  <div class="iryo-description">
    <div class="iryo-description-text">
      <span>事業所紹介サービス</span>
      <p>ご希望に沿った障害福祉サービスをご紹介致します。<br><br>まずは下記のお問い合わせフォームから<br>必要事項をご記入の上、送信ボタンを押して下さい。<br><br>追って、ご連絡致します。</p>
    </div>
    <div class="iryo-description-img">
      <%= image_tag "iryo_contact.svg" %>
    </div>
  </div>
  <%#//サガセルの説明%>

  <div class="module-spacer--large"></div>

  <%#サービスの流れ%>
  <nav class="service-flow">
    <h2 class="about-us-title">ご入居までの流れ</h2>
    <div class="module-spacer--medium"></div>
    <ul class="flow">
      <li>
        <dl>
          <dt><span class="icon">STEP.01</span>ヒアリング</dt>
          <dd>イリョフクの相談員よりご利用者様のご要望を確認させていただきます。</dd>
        </dl>
      </li>

      <li>
        <dl>
          <dt><span class="icon">STEP.02</span>ご紹介先の見学</dt>
          <dd>ご利用者様にぴったりな障害福祉事業所をご紹介。見学や送迎の手配もお任せください。</dd>
        </dl>
      </li>

      <li>
        <dl>
          <dt><span class="icon">STEP.03</span>ご入居の手続き</dt>
          <dd>ご入居先が決まりましたら、病院や相談支援専門員と連携し、必要書類のご用意もお手伝いします。</dd>
        </dl>
      </li>

      <li>
        <dl>
          <dt><span class="icon">STEP.04</span>ご入居開始</dt>
          <dd>ご入居後も障害福祉事業所・病院・相談支援専門員と情報を共有し、常にフォロー致します。</dd>
        </dl>
      </li>
    </ul>
  </nav>
  <%#//サービスの流れ%>

  <div class="module-spacer--large"></div>

  <%# コンタクトフォーム %>
  <%= render partial: 'shared/contact_form', locals: {path: contact_message_iryos_path} %>
  <%#// コンタクトフォーム %>

</section>
<%#//大枠%>

<%= render partial: 'shared/footer' %>

<%= javascript_pack_tag 'shared/reveal' %>